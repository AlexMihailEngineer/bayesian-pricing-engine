{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Bayesian Pricing Engine PoC.",
    "keywords": [
        "laravel",
        "framework",
        "bayesian",
        "dynamic-pricing"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "brick/math": "^0.12.1",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10",
        "league/csv": "^9.16"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Bayesian\\PricingDiscovery\\": "src/PricingDiscovery/",
            "Bayesian\\RiskModeling\\": "src/RiskModeling/",
            "Bayesian\\MarketIngestion\\": "src/MarketIngestion/",
            "Bayesian\\FiscalValidation\\": "src/FiscalValidation/",
            "Bayesian\\Shared\\": "src/Shared/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
