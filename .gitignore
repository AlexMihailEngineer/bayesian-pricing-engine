# =============================================================================
# Bayesian Pricing Engine - Global Ignore Rules
# =============================================================================

# --- Core Dependencies ---
/vendor/
/frontend/node_modules/
.pnp/
.pnp.js

# --- Environment & Security (NEVER COMMIT) ---
.env
.env.*
!.env.example
*.key
phpright.json
.php_cs.cache
.phpunit.result.cache

# --- Laravel Framework Runtime ---
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*
/public/storage
/public/hot
/storage/debugbar/

# Ensure directory structure exists in Git
!/storage/framework/cache/data/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/views/.gitignore
!/storage/logs/.gitignore
!/bootstrap/cache/.gitignore

# --- Frontend (Vite / React 19) ---
/frontend/dist/
/frontend/build/
/frontend/.svelte-kit/
/frontend/.vercel/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vite/

# --- Bayesian Engine & Data Science ---
# We ignore raw datasets to prevent repo bloat, keeping only samples.
.composer/
.phpunit.cache/
test.php
*.csv
*.json_bak
!ecommerce_dynamic_pricing_dataset.example.csv

# --- IDE, OS & Editor Artifacts ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.classpath